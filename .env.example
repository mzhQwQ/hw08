# 大模型 API 密钥配置
# 请在本地复制为 .env 文件并填写你的实际 API 密钥
# .env 文件已添加到 .gitignore，不会被提交到仓库

# 阿里通义千问 API Key
QWEN_API_KEY=sk-your-qwen-api-key-here

# 智谱 GLM API Key
ZHIPU_API_KEY=your-zhipu-api-key-here

# OpenAI API Key
OPENAI_API_KEY=sk-your-openai-api-key-here

# 抖音火山引擎 API 配置（豆包模型）
VOLCANOENGINE_API_KEY=your-volcanoengine-api-key-here

# 默认使用的模型（qwen / zhipu / openai / volcanoengine）
DEFAULT_MODEL=qwen

# Streamlit 应用配置
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_HEADLESS=false
